# ============================================================
# SellerVision AI — Environment Variables
# Copy to .env and fill in all values
# NEVER commit .env to git
# ============================================================

# App
SECRET_KEY=your-secret-key-here-minimum-32-chars
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://sellervision:password@localhost:5432/sellervision
DB_PASSWORD=your-db-password

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your-redis-password

# AI
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1-aws

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Amazon SP-API
AMAZON_CLIENT_ID=amzn1.application...
AMAZON_CLIENT_SECRET=...
AMAZON_REFRESH_TOKEN=Atzr|...
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER

# Walmart
WALMART_CLIENT_ID=...
WALMART_CLIENT_SECRET=...

# Shopify
SHOPIFY_API_KEY=...
SHOPIFY_API_SECRET=...

# eBay
EBAY_APP_ID=...
EBAY_CERT_ID=...
EBAY_DEV_ID=...

# TikTok Shop
TIKTOK_APP_KEY=...
TIKTOK_APP_SECRET=...

# Etsy
ETSY_KEYSTRING=...
ETSY_SHARED_SECRET=...

# AWS
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=sellervision-ai-assets
CLOUDFRONT_DOMAIN=...

# Monitoring
GRAFANA_PASSWORD=...
CORS_ORIGINS=["http://localhost:3000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Email (for notifications)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG...

# Slack (for alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Feature Flags
ENABLE_VOICE_ASSISTANT=true
ENABLE_DIGITAL_TWIN=true
ENABLE_AUTONOMOUS_AGENTS=true
ENABLE_MARKETPLACE=true

# AI Models
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# Resend (Transactional Email)
RESEND_API_KEY=re_...
EMAIL_FROM=SellerVision AI <hello@yourdomain.com>
EMAIL_REPLY_TO=support@yourdomain.com

# Sentry (Error Tracking)
# Backend (server-side, secret — never expose in browser)
SENTRY_DSN=https://...@o....ingest.sentry.io/...
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
# Frontend (public — safe to embed in JS bundle)
NEXT_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...
# Build-time only (CI/CD) — for source map uploads
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=sellervision-frontend

# Google (Trends API)
GOOGLE_API_KEY=...

# Reddit API (Trend Detection)
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=SellerVisionAI/1.0
